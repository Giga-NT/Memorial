// === ВЫБОР СТЕЛЛЫ ===
function selectStele(id) {
    if (isSteleLoading) return;
    
    currentStele = id;
    
    // Подсветка
    document.querySelectorAll('.stele-card').forEach(c => {
        c.style.borderColor = '#333';
        c.style.background = '#222';
    });
    const activeCard = document.querySelector(`.stele-card[data-id="${id}"]`);
    if (activeCard) {
        activeCard.style.borderColor = '#4CAF50';
        activeCard.style.background = '#1a2a1a';
    }
    
    // Загружаем модель
    const stele = STELES.find(s => s.id === id);
    if (stele) {
        loadSteleModel(stele.path);
    }
}

// === ЗАГРУЗКА 3D МОДЕЛИ СТЕЛЛЫ ===
function loadSteleModel(path) {
    if (!scene) {
        setTimeout(() => loadSteleModel(path), 500);
        return;
    }
    
    if (typeof THREE.GLTFLoader === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js';
        document.head.appendChild(script);
        script.onload = () => loadSteleModel(path);
        return;
    }
    
    isSteleLoading = true;
    statusText.textContent = '⏳ Загрузка стеллы...';
    
    // Удаляем старую декаль
    if (decalMesh) {
        scene.remove(decalMesh);
        decalMesh.geometry?.dispose();
        decalMesh.material?.dispose();
        decalMesh = null;
    }
    
    // Удаляем старую стеллу
    if (currentSteleModel) {
        scene.remove(currentSteleModel);
        currentSteleModel = null;
    }
    if (stelaMesh) {
        scene.remove(stelaMesh);
        stelaMesh = null;
        stelaMeshForDecal = null;
    }
    
    const loader = new THREE.GLTFLoader();
    
    loader.load(
        path,
        (gltf) => {
            currentSteleModel = gltf.scene;
            stelaMesh = gltf.scene;
            stelaMeshForDecal = gltf.scene;
            
            // Масштабируем
            const box = new THREE.Box3().setFromObject(stelaMesh);
            const size = box.getSize(new THREE.Vector3());
            const maxDim = Math.max(size.x, size.y, size.z);
            const targetSize = 1.8;
            const scale = targetSize / maxDim;
            stelaMesh.scale.set(scale, scale, scale);
            
            // Центрируем
            const center = box.getCenter(new THREE.Vector3());
            stelaMesh.position.sub(center);
            stelaMesh.position.y += 0.8;
            
            scene.add(stelaMesh);
            
            // Добавляем каркас
            stelaMesh.traverse((child) => {
                if (child.isMesh) {
                    const edges = new THREE.EdgesGeometry(child.geometry);
                    const lineMat = new THREE.LineBasicMaterial({ 
                        color: 0x4CAF50, 
                        transparent: true, 
                        opacity: 0.15 
                    });
                    const wireframe = new THREE.LineSegments(edges, lineMat);
                    child.add(wireframe);
                }
            });
            
            statusText.textContent = '✅ Стелла загружена!';
            isSteleLoading = false;
            
            // Если есть текстура — применяем
            if (currentTexturePath) {
                applyTextureToStela(currentTexturePath);
            }
            
            // Если есть гравировка — наносим
            if (engravingBase64) {
                setTimeout(() => applyToStela(engravingBase64), 500);
            }
            
            console.log('✅ Стелла загружена:', path);
        },
        (progress) => {
            const percent = Math.round((progress.loaded / progress.total) * 100);
            if (progress.total > 0) {
                statusText.textContent = `⏳ Загрузка стеллы: ${percent}%`;
            }
        },
        (error) => {
            console.error('❌ Ошибка загрузки стеллы:', error);
            statusText.textContent = '❌ Ошибка загрузки стеллы';
            isSteleLoading = false;
            createDefaultStela();
        }
    );
}

// === СОЗДАНИЕ СТАНДАРТНОЙ СТЕЛЛЫ ===
function createDefaultStela() {
    if (stelaMesh) {
        scene.remove(stelaMesh);
        stelaMesh = null;
        stelaMeshForDecal = null;
    }
    
    if (currentSteleModel) {
        scene.remove(currentSteleModel);
        currentSteleModel = null;
    }
    
    if (decalMesh) {
        scene.remove(decalMesh);
        decalMesh.geometry?.dispose();
        decalMesh.material?.dispose();
        decalMesh = null;
    }
    
    const stelaWidth = 1.2;
    const stelaHeight = 2.0;
    const stelaDepth = 0.2;
    
    const frontMat = new THREE.MeshStandardMaterial({
        color: 0x888888,
        roughness: 0.6,
        metalness: 0.1,
        side: THREE.DoubleSide
    });
    
    const otherMat = new THREE.MeshStandardMaterial({
        color: 0x444444,
        roughness: 0.8,
        metalness: 0.0,
        side: THREE.DoubleSide
    });
    
    const materials = [
        otherMat, otherMat,
        otherMat, otherMat,
        frontMat, otherMat
    ];
    
    const geometry = new THREE.BoxGeometry(stelaWidth, stelaHeight, stelaDepth);
    stelaMesh = new THREE.Mesh(geometry, materials);
    stelaMesh.position.set(0, 0.8, 0);
    stelaMesh.castShadow = true;
    stelaMesh.receiveShadow = true;
    
    scene.add(stelaMesh);
    stelaMeshForDecal = stelaMesh;
    
    const edgeGeo = new THREE.EdgesGeometry(geometry);
    const edgeMat = new THREE.LineBasicMaterial({ color: 0x444444 });
    const wireframe = new THREE.LineSegments(edgeGeo, edgeMat);
    wireframe.position.copy(stelaMesh.position);
    scene.add(wireframe);
    
    console.log('✅ Стандартная стелла создана');
}



function finalizeDecal(ctx, canvas, canvasSize) {
    if (isDecalApplying) {
        console.log('⏳ Уже применяется, пропускаем');
        return;
    }
    
    try {
        isDecalApplying = true;
        console.log('🔍 finalizeDecal вызвана');
        
        const texture = new THREE.CanvasTexture(canvas);
        texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
        texture.needsUpdate = true;
        
        // ========================================
        // ТВОЯ ЛОГИКА ПОЗИЦИОНИРОВАНИЯ
        // ========================================
        const stelaWidth = 1.2;
        const stelaHeight = 2.0;
        const stelaDepth = 0.2;
        
        const userScale = parseFloat(scaleSlider.value);
        const decalSize = Math.min(stelaWidth, stelaHeight) * 0.85 * userScale;
        
        const offsetXPos = parseFloat(offsetXSlider.value) * 0.3;
        const offsetYPos = parseFloat(offsetYSlider.value) * 0.3;
        const offsetZPos = parseFloat(offsetZSlider.value) * 0.05;
        
        // Позиция (ТВОЯ РОДНАЯ)
        const posX = offsetXPos;
        const posY = 0.8 + offsetYPos;
        const posZ = stelaDepth/2 + 0.01 + offsetZPos;
        
        console.log('🔍 Позиция:', posX, posY, posZ);
        console.log('🔍 Размер:', decalSize);
        
        // ========================================
        // УДАЛЯЕМ СТАРУЮ ГРАВИРОВКУ
        // ========================================
        if (window.currentDecal) {
            scene.remove(window.currentDecal);
            window.currentDecal.geometry?.dispose();
            window.currentDecal.material?.dispose();
            window.currentDecal = null;
        }
        
        // ========================================
        // СОЗДАЁМ ПЛОСКИЙ ОБЪЕКТ ВМЕСТО DECALGEOMETRY
        // ========================================
        const geometry = new THREE.PlaneGeometry(decalSize, decalSize);
        const material = new THREE.MeshStandardMaterial({
            map: texture,
            transparent: true,
            side: THREE.DoubleSide,
            depthWrite: false,
            polygonOffset: true,
            polygonOffsetFactor: -1,
            polygonOffsetUnits: -1,
            opacity: 1.0
        });
        
        const decal = new THREE.Mesh(geometry, material);
        
        // ПОЗИЦИЯ (ТВОЯ)
        decal.position.set(posX, posY, posZ);
        
        // ПОВОРОТ — чтобы смотреть на камеру (вперёд)
        decal.rotation.y = 0;
        
        scene.add(decal);
        window.currentDecal = decal;
        
        statusText.textContent = '✅ Нанесено на стелу!';
        
        // Активируем кнопки
        if (isAuthenticated) {
            printBtn.disabled = false;
            if (orderBtn) orderBtn.disabled = false;
        }
        downloadBtn.disabled = false;
        
        console.log('✅ finalizeDecal завершена');
        
    } catch (e) {
        console.error('❌ Ошибка в finalizeDecal:', e);
        statusText.textContent = '❌ Ошибка нанесения: ' + (e.message || 'неизвестная ошибка');
    } finally {
        setTimeout(() => {
            isDecalApplying = false;
        }, 300);
    }
}

function updateDecalPosition() {
    if (!window.currentDecal) return;
    
    const userScale = parseFloat(scaleSlider.value);
    const decalSize = Math.min(1.2, 2.0) * 0.85 * userScale;
    
    const offsetXPos = parseFloat(offsetXSlider.value) * 0.3;
    const offsetYPos = parseFloat(offsetYSlider.value) * 0.3;
    const offsetZPos = parseFloat(offsetZSlider.value) * 0.05;
    
    const posX = offsetXPos;
    const posY = 0.8 + offsetYPos;
    const posZ = 0.2/2 + 0.01 + offsetZPos;
    
    window.currentDecal.position.set(posX, posY, posZ);
    window.currentDecal.scale.set(1, 1, 1);
    window.currentDecal.geometry.dispose();
    window.currentDecal.geometry = new THREE.PlaneGeometry(decalSize, decalSize);
    
    renderer.render(scene, camera);
}

function createShapeMask(width, height, shapeType) {
    const canvas = document.createElement('canvas');
    canvas.width = width;
    canvas.height = height;
    const ctx = canvas.getContext('2d');
    
    ctx.fillStyle = '#000000';
    ctx.fillRect(0, 0, width, height);
    
    ctx.fillStyle = '#FFFFFF';
    
    const cx = width / 2;
    const cy = height / 2;
    const size = Math.min(width, height);
    
    switch(shapeType) {
        case 'circle':
            ctx.beginPath();
            ctx.arc(cx, cy, size * 0.45, 0, Math.PI * 2);
            ctx.fill();
            break;
        case 'oval':
            ctx.beginPath();
            ctx.ellipse(cx, cy, width * 0.45, height * 0.45, 0, 0, Math.PI * 2);
            ctx.fill();
            break;
        case 'square':
            const sqSize = size * 0.45;
            ctx.fillRect(cx - sqSize, cy - sqSize, sqSize * 2, sqSize * 2);
            break;
        case 'rounded':
            const rSize = size * 0.45;
            const radius = 20;
            ctx.beginPath();
            ctx.moveTo(cx - rSize + radius, cy - rSize);
            ctx.lineTo(cx + rSize - radius, cy - rSize);
            ctx.quadraticCurveTo(cx + rSize, cy - rSize, cx + rSize, cy - rSize + radius);
            ctx.lineTo(cx + rSize, cy + rSize - radius);
            ctx.quadraticCurveTo(cx + rSize, cy + rSize, cx + rSize - radius, cy + rSize);
            ctx.lineTo(cx - rSize + radius, cy + rSize);
            ctx.quadraticCurveTo(cx - rSize, cy + rSize, cx - rSize, cy + rSize - radius);
            ctx.lineTo(cx - rSize, cy - rSize + radius);
            ctx.quadraticCurveTo(cx - rSize, cy - rSize, cx - rSize + radius, cy - rSize);
            ctx.fill();
            break;
        default:
            return null;
    }
    
    return canvas;
}

function applyTextureToStela(texturePath) {
    if (!stelaMesh) return;
    if (isTextureApplying) return;
    if (texturePath === currentTexturePath && stelaTextureLoaded) return;
    
    isTextureApplying = true;
    
    // Находим ВСЕ меши в модели
    let meshes = [];
    if (stelaMesh.isGroup || stelaMesh.children) {
        stelaMesh.traverse((child) => {
            if (child.isMesh) {
                meshes.push(child);
            }
        });
    } else {
        meshes = [stelaMesh];
    }
    
    if (meshes.length === 0) {
        isTextureApplying = false;
        return;
    }
    
    if (!texturePath) {
        // Сбрасываем текстуру для всех мешей
        meshes.forEach(mesh => {
            const material = new THREE.MeshStandardMaterial({
                color: 0x888888,
                roughness: 0.6,
                metalness: 0.1,
                side: THREE.DoubleSide
            });
            mesh.material = material;
        });
        stelaTextureLoaded = null;
        currentTexturePath = null;
        isTextureApplying = false;
        return;
    }
    
    const loader = new THREE.TextureLoader();
    const fullPath = `/texture/${texturePath}`;
    
    loader.load(fullPath, (texture) => {
        texture.wrapS = THREE.RepeatWrapping;
        texture.wrapT = THREE.RepeatWrapping;
        texture.repeat.set(1, 1);
        
        // Применяем текстуру ко ВСЕМ мешам
        meshes.forEach(mesh => {
            const material = new THREE.MeshStandardMaterial({
                map: texture,
                roughness: 0.7,
                metalness: 0.0,
                side: THREE.DoubleSide,
                color: 0xffffff
            });
            mesh.material = material;
            mesh.material.needsUpdate = true;
        });
        
        stelaTextureLoaded = texture;
        currentTexturePath = texturePath;
        
        console.log('✅ Текстура применена к стеле:', texturePath);
        isTextureApplying = false;
        
        // Если есть гравировка — переприменяем
        if (engravingBase64) {
            setTimeout(() => applyToStela(engravingBase64), 300);
        }
    }, undefined, (error) => {
        console.error('❌ Ошибка загрузки текстуры:', error);
        isTextureApplying = false;
    });
}

